{
  "name": "openclaw-extensions",
  "private": true,
  "type": "module",
  "description": "OpenClaw extensions: quality gate engine, skills, and shared schemas",
  "scripts": {
    "prepare": "husky",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @openclaw/product-team test:e2e",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "create:extension": "tsx tools/create-extension/src/cli.ts",
    "q:gate": "tsx scripts/run-root-q-gate.ts",
    "q:tests": "pnpm --filter @openclaw/quality-gate q:cli run --tests",
    "q:coverage": "pnpm --filter @openclaw/quality-gate q:cli run --coverage",
    "q:lint": "pnpm --filter @openclaw/quality-gate q:cli run --lint",
    "q:complexity": "pnpm --filter @openclaw/quality-gate q:cli run --complexity",
    "verify:q-surface": "tsx scripts/verify-root-quality-gate-command-surface.ts",
    "verify:vuln-policy": "tsx scripts/enforce-ci-vulnerability-policy.ts",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "4.0.18",
    "conventional-changelog-cli": "^5.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1"
  }
}
