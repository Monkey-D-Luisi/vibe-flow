      "public_surface": [
        "validate"
      ]
    }
  ],
  "contracts": [
    {
      "id": "snapshot.completed.v1",
      "kind": "event",
      "module": "broadcaster",
      "event": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "taskId",
          "status"
        ],
        "properties": {
          "taskId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "failed"
            ]
          }
        }
      }
    },
    {
      "id": "snapshot.generate.v1",
      "kind": "http",
      "module": "orchestrator",
      "request": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "taskId"
        ],
        "properties": {
          "taskId": {
            "type": "string"
          }
        }
      },
      "response": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "document"
        ],
        "properties": {
          "document": {
            "type": "object"
          }
        }
      },
      "errors": [
        {
          "code": "NOT_FOUND",
          "when": "Unknown task id",
          "http": 404
        }
      ]
    },
    {
      "id": "snapshot.validate.v1",
      "kind": "rpc",
      "module": "validator",
      "request": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "document"
        ],
        "properties": {
          "document": {
            "type": "object"
          }
        }
      },
      "response": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "valid"
        ],
        "properties": {
          "valid": {
            "type": "boolean"
          }
        }
      }
    }
  ],
