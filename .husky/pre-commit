#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "[pre-commit] Running tests (set SKIP_TESTS=1 to bypass under CI control)..."
pnpm precommit:check || {
  echo "[pre-commit] Tests failed. Commit aborted."
  exit 1
}

if [ "${SKIP_ADR:-0}" = "1" ]; then
  echo "[pre-commit] Skipping ADR lint (SKIP_ADR=1)."
else
  pnpm adr:lint:changed || {
    echo "[pre-commit] ADR lint failed. Commit aborted."
    exit 1
  }
fi

if [ "${SKIP_PATTERNS:-0}" = "1" ]; then
  echo "[pre-commit] Skipping pattern lint (SKIP_PATTERNS=1)."
else
  pnpm patterns:lint:changed || {
    echo "[pre-commit] Pattern lint failed. Commit aborted."
    exit 1
  }
fi

if git diff --cached --name-only | grep -Eq '^docs/epics/.+/10-spec\.md$'; then
  if [ "${SKIP_DESIGN_READY:-0}" = "1" ]; then
    echo "[pre-commit] Skipping design_ready generation (SKIP_DESIGN_READY=1)."
  else
    echo "[pre-commit] design_ready spec changes detected. Running generator..."
    pnpm design:gen || {
      echo "[pre-commit] design:gen failed. Commit aborted."
      exit 1
    }
    pnpm design:lint || {
      echo "[pre-commit] design:lint failed. Commit aborted."
      exit 1
    }
    echo "[pre-commit] design_ready artifacts updated. Restage generated files if needed."
  fi
fi
