{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunTestsInput",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "cwd": { "type": "string", "description": "Directory from which to execute" },
    "cmd": { "type": "string", "description": "Test command", "default": "pnpm exec vitest run --reporter=json" },
    "timeoutMs": { "type": "integer", "minimum": 1000, "default": 600000 },
    "envAllow": { "type": "array", "items": { "type": "string" }, "default": ["NODE_ENV"] }
  }
}
