{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CoverageReportInput",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "summaryPath": { "type": "string", "default": "coverage/coverage-summary.json" },
    "lcovPath": { "type": "string", "default": "coverage/lcov.info" },
    "repoRoot": { "type": "string", "default": "." },
    "exclude": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["**/*.test.*", "**/__tests__/**", "**/fixtures/**"]
    }
  }
}
