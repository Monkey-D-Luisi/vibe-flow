{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LintInput",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "cwd": { "type": "string", "description": "Working directory" },
    "tool": { "type": "string", "enum": ["eslint", "ruff"], "default": "eslint" },
    "cmd": { "type": "string", "description": "Linter command to execute; must produce JSON", "default": "pnpm lint -f json" },
    "paths": { "type": "array", "items": { "type": "string" }, "description": "Paths or globs to analyze" },
    "timeoutMs": { "type": "integer", "minimum": 1000, "default": 600000 },
    "envAllow": { "type": "array", "items": { "type": "string" }, "default": ["NODE_ENV"] }
  }
}
