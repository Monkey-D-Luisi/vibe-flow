{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "diff_summary": {
      "type": "string",
      "description": "Summary of code changes"
    },
    "metrics": {
      "type": "object",
      "properties": {
        "coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Test coverage percentage"
        },
        "lint": {
          "type": "object",
          "properties": {
            "errors": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of lint errors"
            },
            "warnings": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of lint warnings"
            }
          },
          "required": ["errors", "warnings"],
          "additionalProperties": false
        }
      },
      "required": ["coverage", "lint"],
      "additionalProperties": false
    },
    "red_green_refactor_log": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2,
      "description": "RGR log entries"
    }
  },
  "required": ["diff_summary", "metrics", "red_green_refactor_log"],
  "additionalProperties": false
}