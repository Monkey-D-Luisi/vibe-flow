{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskRecord",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "id",
    "title",
    "acceptance_criteria",
    "scope",
    "status",
    "rev",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "string",
      "enum": [
        "minor",
        "major"
      ]
    },
    "status": {
      "type": "string"
    },
    "rev": {
      "type": "integer"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
