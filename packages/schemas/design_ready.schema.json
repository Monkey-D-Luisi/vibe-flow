{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "modules": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of modules to implement"
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Z][a-zA-Z0-9]*$",
            "description": "PascalCase contract name"
          },
          "methods": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of methods in the contract"
          }
        },
        "required": ["name", "methods"],
        "additionalProperties": false
      },
      "description": "Interface contracts"
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Pattern name"
          },
          "where": {
            "type": "string",
            "description": "Where to apply the pattern"
          },
          "why": {
            "type": "string",
            "description": "Why this pattern is chosen"
          }
        },
        "required": ["name", "where", "why"],
        "additionalProperties": false
      },
      "description": "Design patterns to use"
    },
    "adr_id": {
      "type": "string",
      "pattern": "^ADR-\\d+$",
      "description": "ADR identifier"
    },
    "test_plan": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Testing strategy and plan"
    }
  },
  "required": ["modules", "contracts", "patterns", "adr_id", "test_plan"],
  "additionalProperties": false
}