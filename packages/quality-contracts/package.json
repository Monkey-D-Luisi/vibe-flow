{
  "name": "@openclaw/quality-contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared quality parser and gate policy contracts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts --no-cache",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    "./parsers/types": {
      "types": "./src/parsers/types.ts",
      "default": "./src/parsers/types.ts"
    },
    "./parsers/eslint": {
      "types": "./src/parsers/eslint.ts",
      "default": "./src/parsers/eslint.ts"
    },
    "./parsers/ruff": {
      "types": "./src/parsers/ruff.ts",
      "default": "./src/parsers/ruff.ts"
    },
    "./parsers/istanbul": {
      "types": "./src/parsers/istanbul.ts",
      "default": "./src/parsers/istanbul.ts"
    },
    "./parsers/vitest": {
      "types": "./src/parsers/vitest.ts",
      "default": "./src/parsers/vitest.ts"
    },
    "./gate/types": {
      "types": "./src/gate/types.ts",
      "default": "./src/gate/types.ts"
    },
    "./gate/policy": {
      "types": "./src/gate/policy.ts",
      "default": "./src/gate/policy.ts"
    },
    "./gate/auto-tune": {
      "types": "./src/gate/auto-tune.ts",
      "default": "./src/gate/auto-tune.ts"
    },
    "./gate/alerts": {
      "types": "./src/gate/alerts.ts",
      "default": "./src/gate/alerts.ts"
    },
    "./gate/sources": {
      "types": "./src/gate/sources.ts",
      "default": "./src/gate/sources.ts"
    },
    "./exec/spawn": {
      "types": "./src/exec/spawn.ts",
      "default": "./src/exec/spawn.ts"
    },
    "./fs/glob": {
      "types": "./src/fs/glob.ts",
      "default": "./src/fs/glob.ts"
    },
    "./fs/read": {
      "types": "./src/fs/read.ts",
      "default": "./src/fs/read.ts"
    },
    "./complexity/types": {
      "types": "./src/complexity/types.ts",
      "default": "./src/complexity/types.ts"
    },
    "./complexity/escomplex": {
      "types": "./src/complexity/escomplex.ts",
      "default": "./src/complexity/escomplex.ts"
    },
    "./complexity/tsmorph": {
      "types": "./src/complexity/tsmorph.ts",
      "default": "./src/complexity/tsmorph.ts"
    },
    "./validate/tools": {
      "types": "./src/validate/tools.ts",
      "default": "./src/validate/tools.ts"
    },
    "./schemas/messages": {
      "types": "./src/schemas/messages/index.ts",
      "default": "./src/schemas/messages/index.ts"
    },
    "./schemas/protocol-header": {
      "types": "./src/schemas/protocol-header.ts",
      "default": "./src/schemas/protocol-header.ts"
    },
    "./validation/message-validator": {
      "types": "./src/validation/message-validator.ts",
      "default": "./src/validation/message-validator.ts"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "fast-glob": "^3.3.2",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "^10.1.0",
    "typescript": "^5.7.0",
    "vitest": "4.1.2"
  }
}
