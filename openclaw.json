{
  "plugins": {
    "load": {
      "paths": ["./extensions/product-team"]
    },
    "entries": {
      "product-team": {
        "enabled": true,
        "config": {
          "dbPath": "./data/product-team.db",
          "github": {
            "owner": "<your-github-owner>",
            "repo": "<your-github-repo>",
            "defaultBase": "main"
          }
        }
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": ["./skills"]
    }
  },
  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-20250514",
      "sandbox": {
        "mode": "non-main",
        "scope": "agent",
        "workspaceAccess": "rw"
      }
    },
    "list": [
      {
        "id": "pm",
        "name": "Product Manager",
        "default": true,
        "workspace": "~/.openclaw/workspaces/product-team/pm",
        "tools": {
          "allow": [
            "task_create",
            "task_get",
            "task_search",
            "task_update",
            "task_transition"
          ]
        }
      },
      {
        "id": "architect",
        "name": "Software Architect",
        "workspace": "~/.openclaw/workspaces/product-team/architect",
        "tools": {
          "allow": [
            "task_get",
            "task_update",
            "task_transition",
            "workflow_state_get"
          ]
        }
      },
      {
        "id": "dev",
        "name": "Developer",
        "workspace": "~/.openclaw/workspaces/product-team/dev",
        "tools": {
          "allow": [
            "task_get",
            "task_update",
            "task_transition",
            "quality_coverage",
            "quality_lint",
            "quality_complexity",
            "workflow_step_run",
            "workflow_state_get"
          ]
        }
      },
      {
        "id": "qa",
        "name": "QA Engineer",
        "workspace": "~/.openclaw/workspaces/product-team/qa",
        "tools": {
          "allow": [
            "task_get",
            "task_update",
            "task_transition",
            "quality_coverage",
            "quality_lint",
            "quality_complexity"
          ]
        }
      },
      {
        "id": "reviewer",
        "name": "Code Reviewer",
        "workspace": "~/.openclaw/workspaces/product-team/reviewer",
        "tools": {
          "allow": [
            "task_get",
            "task_update",
            "task_transition"
          ]
        }
      },
      {
        "id": "infra",
        "name": "Infrastructure Engineer",
        "workspace": "~/.openclaw/workspaces/product-team/infra",
        "tools": {
          "allow": [
            "vcs_branch_create",
            "vcs_pr_create",
            "vcs_pr_update",
            "vcs_label_sync",
            "task_get",
            "task_transition"
          ]
        }
      }
    ]
  }
}
