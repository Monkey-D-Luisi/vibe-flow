{
  "plugins": {
    "load": {
      "paths": ["./extensions/product-team"]
    },
    "entries": {
      "product-team": {
        "enabled": true,
        "config": {
          "dbPath": "./data/product-team.db",
          "github": {
            "owner": "<your-github-owner>",
            "repo": "<your-github-repo>",
            "defaultBase": "main",
            "prBot": {
              "enabled": true,
              "reviewers": {
                "default": [],
                "major": [],
                "minor": [],
                "patch": []
              }
            }
          }
        }
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": ["./skills"]
    }
  },
  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-20250514",
      "sandbox": {
        "mode": "non-main",
        "scope": "agent",
        "workspaceAccess": "rw"
      }
    },
    "list": [
      {
        "id": "pm",
        "name": "Product Manager",
        "default": true,
        "workspace": "~/.openclaw/workspaces/product-team/pm",
        "tools": {
          "allow": [
            "task.create",
            "task.get",
            "task.search",
            "task.update",
            "task.transition"
          ]
        }
      },
      {
        "id": "architect",
        "name": "Software Architect",
        "workspace": "~/.openclaw/workspaces/product-team/architect",
        "tools": {
          "allow": [
            "task.get",
            "task.update",
            "task.transition",
            "workflow.state.get"
          ]
        }
      },
      {
        "id": "dev",
        "name": "Developer",
        "workspace": "~/.openclaw/workspaces/product-team/dev",
        "tools": {
          "allow": [
            "task.get",
            "task.update",
            "task.transition",
            "quality.tests",
            "quality.coverage",
            "quality.lint",
            "quality.complexity",
            "quality.gate",
            "workflow.step.run",
            "workflow.state.get"
          ]
        }
      },
      {
        "id": "qa",
        "name": "QA Engineer",
        "workspace": "~/.openclaw/workspaces/product-team/qa",
        "tools": {
          "allow": [
            "task.get",
            "task.update",
            "task.transition",
            "quality.tests",
            "quality.coverage",
            "quality.lint",
            "quality.complexity"
          ]
        }
      },
      {
        "id": "reviewer",
        "name": "Code Reviewer",
        "workspace": "~/.openclaw/workspaces/product-team/reviewer",
        "tools": {
          "allow": [
            "task.get",
            "task.update",
            "task.transition"
          ]
        }
      },
      {
        "id": "infra",
        "name": "Infrastructure Engineer",
        "workspace": "~/.openclaw/workspaces/product-team/infra",
        "tools": {
          "allow": [
            "vcs.branch.create",
            "vcs.pr.create",
            "vcs.pr.update",
            "vcs.label.sync",
            "task.get",
            "task.search",
            "workflow.state.get",
            "workflow.events.query"
          ]
        }
      }
    ]
  }
}
