npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Env files
.env
.env.*
!.env.example
!.env.docker.example

# Docker secrets (mounted at runtime, never committed)
secrets/

# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json

# Husky
.husky/_/

# Cache
.cache/
.eslintcache
.turbo/

# Tests
.jest-cache/

# Benchmark output (generated by perf:bench)
docs/benchmarks/current.json

# Temporary files
*.tmp
*.temp
~$*

# Git
.gitmessage.txt

# Quality reports
.qreport/

# Misc
*.swp
*.swo

actions-runner/
.mcp.json
