# ─────────────────────────────────────────────────────────────
# OpenClaw Autonomous Product Team — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.docker and fill in real values.
# NEVER commit .env.docker — it contains secrets.
# ─────────────────────────────────────────────────────────────

# ── LLM Provider Tokens ──
# All 3 providers authenticate via tokens / OAuth credentials stored in
# auth-profiles.json inside the Docker volume (/root/.openclaw/agents/main/agent/).
# NO provider tokens go in this env file. See docs/docker-setup.md for how to
# obtain and install them.
#
# The three configured providers:
#
#   anthropic:default     — mode: token   (from `claude setup-token`)
#   openai-codex:default  — mode: oauth   (OpenAI Codex OAuth: access + refresh tokens)
#   github-copilot:github — mode: token   (GitHub Copilot device-flow `ghu_` token)
#
# All tokens live in: /root/.openclaw/agents/main/agent/auth-profiles.json

# ── Audio Transcription (optional) ──
# This OpenAI API key is ONLY used for audio transcription (gpt-4o-mini-transcribe).
# It is NOT used for agent models (those use openai-codex OAuth via auth-profiles.json).
# Set tools.media.audio.enabled=false in openclaw.docker.json if you don't need it.
OPENAI_API_KEY=sk-proj-REPLACE_ME

# ── External Services ──

# GitHub (for VCS operations: branches, PRs, labels)
GITHUB_TOKEN=ghp_REPLACE_ME
GITHUB_OWNER=REPLACE_ME
GITHUB_REPO=REPLACE_ME

# GitHub Webhook (for CI feedback; set enabled=true in openclaw.docker.json when ready)
GITHUB_WEBHOOK_SECRET=REPLACE_ME

# Telegram Bot (created via @BotFather)
TELEGRAM_BOT_TOKEN=123456789:REPLACE_ME
TELEGRAM_GROUP_ID=-100REPLACE_ME

# Stitch MCP (Google design tool)
STITCH_API_KEY=REPLACE_ME

# ── Optional ──

# Health check endpoint auth (leave empty for unauthenticated, internal networks only)
HEALTH_CHECK_SECRET=

# Gateway Auth Token (required for LAN bind mode — any random string)
OPENCLAW_GATEWAY_TOKEN=ocgw_REPLACE_ME
