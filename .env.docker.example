# ─────────────────────────────────────────────────────────────
# OpenClaw Autonomous Product Team — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.docker and fill in real values.
# NEVER commit .env.docker — it contains secrets.
# ─────────────────────────────────────────────────────────────

# ── LLM Provider Auth Profiles ──
# Auth is managed via openclaw.docker.json auth.profiles + auth-profiles.json.
# The profiles below correspond to the three configured providers:
#
#   anthropic:default     — mode: token   (Anthropic API token)
#   openai-codex:default  — mode: oauth   (OpenAI Codex OAuth JWT + refresh token)
#   github-copilot:github — mode: token   (GitHub user token for Copilot proxy)
#
# Tokens/credentials are stored in agents/<id>/agent/auth-profiles.json,
# NOT in environment variables. Run `openclaw auth login <provider>` to
# set up each profile interactively.

# OpenAI API key — used ONLY for audio transcription (gpt-4o-mini-transcribe).
# The main LLM provider for OpenAI models is openai-codex via OAuth, not this key.
OPENAI_API_KEY=sk-proj-REPLACE_ME

# ── External Services ──

# GitHub (for VCS operations: branches, PRs, labels)
GITHUB_TOKEN=ghp_REPLACE_ME
GITHUB_OWNER=REPLACE_ME
GITHUB_REPO=REPLACE_ME

# GitHub Webhook (for CI feedback; set enabled=true in openclaw.docker.json when ready)
GITHUB_WEBHOOK_SECRET=REPLACE_ME

# Telegram Bot (created via @BotFather)
TELEGRAM_BOT_TOKEN=123456789:REPLACE_ME
TELEGRAM_GROUP_ID=-100REPLACE_ME

# Stitch MCP (Google design tool)
STITCH_API_KEY=REPLACE_ME

# ── Optional ──

# Health check endpoint auth (leave empty for unauthenticated, internal networks only)
HEALTH_CHECK_SECRET=
