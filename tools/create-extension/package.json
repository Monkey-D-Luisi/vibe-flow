{
  "name": "@openclaw/create-extension",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI scaffolding tool for new OpenClaw extension packages",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts test/**/*.ts --no-cache",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@vitest/coverage-v8": "4.1.2",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "typescript": "^5.7.0",
    "vitest": "4.1.2"
  }
}
