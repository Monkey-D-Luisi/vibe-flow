{
  "name": "@openclaw/product-team",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw plugin for product-team workflow: TaskRecord lifecycle, quality gates, GitHub automation",
  "main": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:e2e": "vitest run --reporter=verbose test/e2e/",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts --no-cache",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "@openclaw/quality-contracts": "workspace:*",
    "@sinclair/typebox": "^0.34.0",
    "ajv": "8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^11.10.0",
    "fast-glob": "^3.3.2",
    "openclaw": "2026.2.22-2",
    "picomatch": "2.3.1",
    "ts-morph": "^23.0.0",
    "typhonjs-escomplex": "^0.1.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.5.4",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
