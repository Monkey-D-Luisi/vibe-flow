{
  "id": "product-team",
  "name": "Product Team Engine",
  "version": "0.1.0",
  "description": "Task engine and workflow tools for a multi-agent product development team",
  "skills": [
    "../../skills/adr",
    "../../skills/architecture-design",
    "../../skills/backend-dev",
    "../../skills/code-review",
    "../../skills/devops",
    "../../skills/frontend-dev",
    "../../skills/github-automation",
    "../../skills/patterns",
    "../../skills/product-owner",
    "../../skills/qa-testing",
    "../../skills/requirements-grooming",
    "../../skills/tdd-implementation",
    "../../skills/tech-lead",
    "../../skills/ui-designer"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dbPath": {
        "type": "string",
        "description": "Path to SQLite database file",
        "default": "./data/product-team.db"
      },
      "github": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "owner": { "type": "string" },
          "repo": { "type": "string" },
          "defaultBase": { "type": "string", "default": "main" },
          "timeoutMs": { "type": "integer", "minimum": 1, "default": 30000 },
          "prBot": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "reviewers": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "default": { "type": "array", "items": { "type": "string" }, "default": [] },
                  "major": { "type": "array", "items": { "type": "string" }, "default": [] },
                  "minor": { "type": "array", "items": { "type": "string" }, "default": [] },
                  "patch": { "type": "array", "items": { "type": "string" }, "default": [] }
                }
              }
            }
          },
          "ciFeedback": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "routePath": { "type": "string", "default": "/webhooks/github/ci" },
              "webhookSecret": { "type": "string", "minLength": 1 },
              "commentOnPr": { "type": "boolean", "default": true },
              "autoTransition": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": false },
                  "toStatus": {
                    "type": "string",
                    "enum": ["backlog", "grooming", "design", "in_progress", "in_review", "qa", "done"]
                  },
                  "agentId": { "type": "string", "default": "infra" }
                }
              }
            }
          }
        }
      },
      "workflow": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "transitionGuards": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "coverage": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "major": { "type": "number", "minimum": 0, "maximum": 100, "default": 80 },
                  "minor": { "type": "number", "minimum": 0, "maximum": 100, "default": 70 },
                  "patch": { "type": "number", "minimum": 0, "maximum": 100, "default": 70 }
                }
              },
              "maxReviewRounds": { "type": "integer", "minimum": 1, "default": 3 }
            }
          },
          "concurrency": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "maxLeasesPerAgent": { "type": "integer", "minimum": 1, "default": 3 },
              "maxTotalLeases": { "type": "integer", "minimum": 1, "default": 10 }
            }
          }
        }
      },
      "projects": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "repo": { "type": "string" },
            "defaultBranch": { "type": "string", "default": "main" },
            "workspace": { "type": "string" },
            "stitch": { "type": "object" },
            "quality": { "type": "object" }
          },
          "required": ["id", "name", "repo", "workspace"]
        }
      },
      "activeProject": {
        "type": "string",
        "description": "Currently active project ID"
      },
      "orchestrator": {
        "type": "object",
        "properties": {
          "maxParallelTasks": { "type": "integer", "minimum": 1, "default": 5 },
          "maxRetriesPerStage": { "type": "integer", "minimum": 0, "default": 1 },
          "stageTimeouts": { "type": "object" },
          "autoEscalateAfterRetries": { "type": "boolean", "default": true },
          "notifyTelegramOnStageChange": { "type": "boolean", "default": true },
          "skipDesignForNonUITasks": { "type": "boolean", "default": true }
        }
      },
      "decisions": {
        "type": "object",
        "properties": {
          "policies": { "type": "object" },
          "timeoutMs": { "type": "integer", "minimum": 1000 },
          "humanApprovalTimeout": { "type": "integer", "minimum": 1000 }
        }
      }
    }
  }
}
