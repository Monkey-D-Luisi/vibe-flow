{
  "name": "@openclaw/stitch-bridge",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw plugin that proxies Google Stitch MCP design tools for the designer agent",
  "main": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts --no-cache",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "openclaw": "2026.3.28"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@vitest/coverage-v8": "4.1.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "typescript": "^5.7.0",
    "vitest": "4.1.2"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
