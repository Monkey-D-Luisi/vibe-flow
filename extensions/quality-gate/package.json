{
  "name": "@openclaw/quality-gate",
  "version": "0.1.0",
  "type": "module",
  "description": "Quality gate extension for OpenClaw: test runner, coverage, lint, complexity, and gate enforcement",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/**/*.ts --no-cache",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "q:cli": "tsx cli/qcli.ts"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "fast-glob": "^3.3.2",
    "picomatch": "2.3.1",
    "ts-morph": "^23.0.0",
    "typhonjs-escomplex": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^2.0.5",
    "eslint": "^8.57.0",
    "tsx": "^4.16.0",
    "typescript": "^5.6.2",
    "vitest": "^2.0.5"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
