{
  "name": "@openclaw/quality-gate",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "description": "Quality gate extension for OpenClaw: test runner, coverage, lint, complexity, and gate enforcement",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint src/**/*.ts --no-cache",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "q:cli": "tsx cli/qcli.ts"
  },
  "dependencies": {
    "@openclaw/quality-contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
