{
  "id": "quality-gate",
  "configSchema": {
    "type": "object",
    "properties": {
      "coverageMinor": {
        "type": "number",
        "description": "Minimum coverage percentage for minor scope",
        "default": 0.70
      },
      "coverageMajor": {
        "type": "number",
        "description": "Minimum coverage percentage for major scope",
        "default": 0.80
      },
      "maxAvgCyclomatic": {
        "type": "number",
        "description": "Maximum average cyclomatic complexity",
        "default": 5.0
      }
    },
    "additionalProperties": false
  }
}
