{
  "name": "@openclaw/telegram-notifier",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw plugin that bridges agent activity to a Telegram group and accepts human commands",
  "main": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts --no-cache",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "openclaw": "2026.3.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
