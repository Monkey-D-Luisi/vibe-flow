{
  "gateway": {
    "port": 28789,
    "bind": "0.0.0.0",
    "controlUi": {
      "enabled": true,
      "basePath": "/"
    },
    "auth": {
      "mode": "none"
    },
    "reload": {
      "mode": "hot"
    }
  },

  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      },
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      },
      "github-copilot:github": {
        "provider": "github-copilot",
        "mode": "token"
      }
    }
  },

  "models": {
    "mode": "merge",
    "providers": {
      "github-copilot": {
        "baseUrl": "https://api.individual.githubcopilot.com",
        "models": []
      }
    }
  },

  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "scope": { "default": "allow" },
        "models": [
          { "provider": "openai", "model": "gpt-4o-mini-transcribe" }
        ]
      }
    }
  },

  "messages": {
    "responsePrefix": "[{provider}/{model}]\n\n",
    "ackReactionScope": "group-mentions"
  },

  "plugins": {
    "load": {
      "paths": [
        "./extensions/product-team",
        "./extensions/quality-gate",
        "./extensions/telegram-notifier",
        "./extensions/model-router",
        "./extensions/stitch-bridge",
        "./extensions/team-ui"
      ]
    },
    "entries": {
      "product-team": {
        "enabled": true,
        "config": {
          "dbPath": "/app/data/product-team.db",
          "github": {
            "owner": "${GITHUB_OWNER:-openclaw}",
            "repo": "${GITHUB_REPO:-vibe-flow}",
            "defaultBase": "main",
            "prBot": {
              "enabled": true,
              "reviewers": {
                "default": [],
                "major": [],
                "minor": [],
                "patch": []
              }
            },
            "ciFeedback": {
              "enabled": false,
              "routePath": "/webhooks/github/ci",
              "webhookSecret": "${GITHUB_WEBHOOK_SECRET:-}",
              "commentOnPr": true,
              "autoTransition": {
                "enabled": true,
                "toStatus": "qa",
                "agentId": "devops"
              }
            }
          },
          "workflow": {
            "transitionGuards": {
              "coverage": {
                "major": 80,
                "minor": 70
              },
              "maxReviewRounds": 3
            },
            "concurrency": {
              "maxLeasesPerAgent": 2,
              "maxTotalLeases": 10
            }
          },
          "projects": [
            {
              "id": "vibe-flow",
              "name": "OpenClaw Extensions",
              "repo": "luiss/vibe-flow",
              "defaultBranch": "main",
              "workspace": "/workspaces/vibe-flow",
              "stitch": { "projectId": null },
              "quality": { "coverageMajor": 80, "coverageMinor": 70, "maxComplexity": 5.0 }
            },
            {
              "id": "saas-template",
              "name": "SaaS Template",
              "repo": "luiss/saas-template",
              "defaultBranch": "main",
              "workspace": "/workspaces/saas-template",
              "stitch": { "projectId": "16786124142182555397" },
              "quality": { "coverageMajor": 80, "coverageMinor": 70, "maxComplexity": 5.0 }
            }
          ],
          "activeProject": "vibe-flow",
          "orchestrator": {
            "maxParallelTasks": 5,
            "maxRetriesPerStage": 1,
            "stageTimeouts": {
              "ROADMAP": 300000,
              "REFINEMENT": 300000,
              "DECOMPOSITION": 300000,
              "DESIGN": 600000,
              "IMPLEMENTATION": 1800000,
              "QA": 600000,
              "REVIEW": 300000,
              "SHIPPING": 300000
            },
            "autoEscalateAfterRetries": true,
            "notifyTelegramOnStageChange": true,
            "skipDesignForNonUITasks": true
          },
          "decisions": {
            "policies": {
              "technical": { "action": "auto", "notify": false },
              "scope": { "action": "escalate", "target": "tech-lead", "notify": true },
              "quality": { "action": "escalate", "target": "tech-lead", "notify": true },
              "conflict": { "action": "escalate", "target": "po", "notify": true },
              "budget": { "action": "pause", "notify": true },
              "blocker": { "action": "retry", "maxRetries": 2, "notify": true }
            },
            "timeoutMs": 300000,
            "humanApprovalTimeout": 3600000
          }
        }
      },
      "quality-gate": {
        "enabled": true,
        "config": {
          "coverageMinor": 70,
          "coverageMajor": 80,
          "maxAvgCyclomatic": 5.0
        }
      },
      "telegram-notifier": {
        "enabled": true,
        "config": {
          "groupId": "${TELEGRAM_GROUP_ID}",
          "rateLimit": {
            "maxPerMinute": 20
          }
        }
      },
      "stitch-bridge": {
        "enabled": true,
        "config": {
          "endpoint": "https://stitch.googleapis.com/mcp",
          "defaultProjectId": "16786124142182555397",
          "defaultModel": "GEMINI_3_PRO",
          "timeoutMs": 60000,
          "designDir": ".stitch-html"
        }
      },
      "model-router": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      },
      "team-ui": {
        "enabled": true,
        "config": {
          "basePath": "/team"
        }
      }
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streamMode": "partial"
    }
  },

  "skills": {
    "load": {
      "extraDirs": ["./skills"]
    }
  },

  "routing": {
    "bindings": [
      {
        "agentId": "pm",
        "match": { "channel": "telegram" }
      }
    ]
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": [
          "openai-codex/gpt-5.2",
          "github-copilot/gpt-4o"
        ]
      },
      "sandbox": {
        "mode": "non-main",
        "scope": "agent",
        "workspaceAccess": "rw"
      }
    },
    "list": [
      {
        "id": "pm",
        "name": "Product Manager",
        "default": true,
        "model": { "primary": "openai-codex/gpt-5.2", "fallbacks": ["anthropic/claude-sonnet-4-6", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["requirements-grooming"],
        "tools": {
          "allow": [
            "task.create", "task.get", "task.search", "task.update",
            "task.transition", "workflow.events.query",
            "project.list", "project.switch",
            "team.assign", "team.status", "team.message",
            "pipeline.start", "pipeline.status",
            "decision.evaluate", "decision.log"
          ]
        }
      },
      {
        "id": "tech-lead",
        "name": "Tech Lead",
        "model": { "primary": "anthropic/claude-opus-4-6", "fallbacks": ["openai-codex/gpt-5.2", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["tech-lead", "architecture-design", "code-review", "adr"],
        "tools": {
          "allow": [
            "task.create", "task.get", "task.search", "task.update",
            "task.transition", "workflow.step.run", "workflow.state.get",
            "workflow.events.query", "quality.gate",
            "team.assign", "team.status", "team.message", "team.inbox", "team.reply",
            "project.list", "project.switch",
            "pipeline.status", "pipeline.retry", "pipeline.skip",
            "decision.evaluate", "decision.log"
          ]
        }
      },
      {
        "id": "po",
        "name": "Product Owner",
        "model": { "primary": "openai-codex/gpt-4.1", "fallbacks": ["anthropic/claude-sonnet-4-6", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["product-owner", "requirements-grooming"],
        "tools": {
          "allow": [
            "task.create", "task.get", "task.search", "task.update",
            "task.transition", "workflow.step.run", "workflow.state.get",
            "team.message", "team.inbox", "team.reply", "team.status",
            "decision.evaluate", "decision.log"
          ]
        }
      },
      {
        "id": "designer",
        "name": "UI/UX Designer",
        "model": { "primary": "openai-codex/gpt-4o", "fallbacks": ["anthropic/claude-sonnet-4-6", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["ui-designer"],
        "tools": {
          "allow": [
            "task.get", "task.update", "task.transition",
            "workflow.step.run", "workflow.state.get",
            "design.generate", "design.edit", "design.get", "design.list",
            "team.message", "team.inbox", "team.reply",
            "decision.evaluate"
          ]
        }
      },
      {
        "id": "back-1",
        "name": "Senior Backend Developer",
        "model": { "primary": "anthropic/claude-sonnet-4-6", "fallbacks": ["openai-codex/gpt-5.2", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["backend-dev", "tdd-implementation", "patterns"],
        "tools": {
          "allow": [
            "task.get", "task.update", "task.transition",
            "workflow.step.run", "workflow.state.get",
            "quality.tests", "quality.coverage", "quality.lint",
            "quality.complexity", "quality.gate",
            "team.message", "team.inbox", "team.reply",
            "decision.evaluate"
          ]
        }
      },
      {
        "id": "back-2",
        "name": "Junior Backend Developer",
        "model": { "primary": "anthropic/claude-sonnet-4-6", "fallbacks": ["openai-codex/gpt-5.2", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["backend-dev", "tdd-implementation"],
        "tools": {
          "allow": [
            "task.get", "task.update", "task.transition",
            "workflow.step.run", "workflow.state.get",
            "quality.tests", "quality.coverage", "quality.lint",
            "quality.complexity", "quality.gate",
            "team.message", "team.inbox", "team.reply",
            "decision.evaluate"
          ]
        }
      },
      {
        "id": "front-1",
        "name": "Senior Frontend Developer",
        "model": { "primary": "anthropic/claude-sonnet-4-6", "fallbacks": ["openai-codex/gpt-5.2", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["frontend-dev", "tdd-implementation"],
        "tools": {
          "allow": [
            "task.get", "task.update", "task.transition",
            "workflow.step.run", "workflow.state.get",
            "quality.tests", "quality.coverage", "quality.lint",
            "quality.complexity", "quality.gate",
            "design.get", "design.list",
            "team.message", "team.inbox", "team.reply",
            "decision.evaluate"
          ]
        }
      },
      {
        "id": "front-2",
        "name": "Junior Frontend Developer",
        "model": { "primary": "anthropic/claude-sonnet-4-6", "fallbacks": ["openai-codex/gpt-5.2", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["frontend-dev", "tdd-implementation"],
        "tools": {
          "allow": [
            "task.get", "task.update", "task.transition",
            "workflow.step.run", "workflow.state.get",
            "quality.tests", "quality.coverage", "quality.lint",
            "quality.complexity", "quality.gate",
            "design.get", "design.list",
            "team.message", "team.inbox", "team.reply",
            "decision.evaluate"
          ]
        }
      },
      {
        "id": "qa",
        "name": "QA Engineer",
        "model": { "primary": "anthropic/claude-sonnet-4-6", "fallbacks": ["openai-codex/gpt-5.2", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["qa-testing"],
        "tools": {
          "allow": [
            "task.get", "task.update", "task.transition",
            "workflow.step.run", "workflow.state.get",
            "quality.tests", "quality.coverage", "quality.lint",
            "quality.complexity", "quality.gate",
            "workflow.events.query",
            "team.message", "team.inbox", "team.reply",
            "decision.evaluate"
          ]
        }
      },
      {
        "id": "devops",
        "name": "DevOps Engineer",
        "model": { "primary": "anthropic/claude-sonnet-4-6", "fallbacks": ["openai-codex/gpt-5.2", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["github-automation"],
        "tools": {
          "allow": [
            "vcs.branch.create", "vcs.pr.create", "vcs.pr.update",
            "vcs.label.sync", "task.get", "task.search", "task.update",
            "task.transition", "workflow.state.get", "workflow.events.query",
            "project.list", "project.switch",
            "team.message", "team.inbox", "team.reply",
            "pipeline.status",
            "decision.evaluate"
          ]
        }
      }
    ]
  },

  "ui": {
    "seamColor": "#6366f1",
    "assistant": {
      "name": "Product Team",
      "avatar": "🏭"
    }
  }
}
