{
  "gateway": {
    "mode": "local",
    "port": 28789,
    "bind": "lan",
    "controlUi": {
      "enabled": true,
      "basePath": "/"
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "reload": {
      "mode": "hot"
    }
  },

  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      },
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      },
      "github-copilot:github": {
        "provider": "github-copilot",
        "mode": "token"
      }
    }
  },

  "models": {
    "mode": "merge",
    "providers": {
      "github-copilot": {
        "baseUrl": "https://api.individual.githubcopilot.com",
        "models": []
      }
    }
  },

  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "scope": { "default": "allow" },
        "models": [
          { "provider": "openai", "model": "gpt-4o-mini-transcribe" }
        ]
      }
    }
  },

  "messages": {
    "responsePrefix": "[{identityName} | {provider}/{model}]\n\n",
    "ackReactionScope": "group-mentions"
  },

  "plugins": {
    "load": {
      "paths": [
        "/app/extensions/product-team",
        "/app/extensions/quality-gate",
        "/app/extensions/telegram-notifier",
        "/app/extensions/model-router",
        "/app/extensions/stitch-bridge"
      ]
    },
    "entries": {
      "product-team": {
        "enabled": true,
        "config": {
          "dbPath": "/app/data/product-team.db",
          "github": {
            "owner": "${GITHUB_OWNER:-openclaw}",
            "repo": "${GITHUB_REPO:-vibe-flow}",
            "defaultBase": "main",
            "prBot": {
              "enabled": true,
              "reviewers": {
                "default": [],
                "major": [],
                "minor": [],
                "patch": []
              }
            },
            "ciFeedback": {
              "enabled": false,
              "routePath": "/webhooks/github/ci",
              "webhookSecret": "${GITHUB_WEBHOOK_SECRET:-}",
              "commentOnPr": true,
              "autoTransition": {
                "enabled": true,
                "toStatus": "qa",
                "agentId": "devops"
              }
            }
          },
          "workflow": {
            "transitionGuards": {
              "coverage": {
                "major": 80,
                "minor": 70
              },
              "maxReviewRounds": 3
            },
            "concurrency": {
              "maxLeasesPerAgent": 2,
              "maxTotalLeases": 10
            }
          },
          "projects": [
            {
              "id": "vibe-flow",
              "name": "OpenClaw Extensions",
              "repo": "Monkey-D-Luisi/vibe-flow",
              "defaultBranch": "main",
              "workspace": "/workspaces/vibe-flow",
              "stitch": { "projectId": null },
              "quality": { "coverageMajor": 80, "coverageMinor": 70, "maxComplexity": 5.0 }
            },
            {
              "id": "saas-template",
              "name": "SaaS Template",
              "repo": "Monkey-D-Luisi/saas-template",
              "defaultBranch": "main",
              "workspace": "/workspaces/saas-template",
              "stitch": { "projectId": "16786124142182555397" },
              "quality": { "coverageMajor": 80, "coverageMinor": 70, "maxComplexity": 5.0 }
            }
          ],
          "activeProject": "vibe-flow",
          "orchestrator": {
            "maxParallelTasks": 5,
            "maxRetriesPerStage": 1,
            "stageTimeouts": {
              "ROADMAP": 300000,
              "REFINEMENT": 300000,
              "DECOMPOSITION": 300000,
              "DESIGN": 600000,
              "IMPLEMENTATION": 1800000,
              "QA": 600000,
              "REVIEW": 300000,
              "SHIPPING": 300000
            },
            "autoEscalateAfterRetries": true,
            "notifyTelegramOnStageChange": true,
            "skipDesignForNonUITasks": true
          },
          "decisions": {
            "policies": {
              "technical": { "action": "auto", "notify": false },
              "scope": { "action": "escalate", "target": "tech-lead", "notify": true },
              "quality": { "action": "escalate", "target": "tech-lead", "notify": true },
              "conflict": { "action": "escalate", "target": "po", "notify": true },
              "budget": { "action": "pause", "notify": true },
              "blocker": { "action": "retry", "maxRetries": 2, "notify": true }
            },
            "timeoutMs": 300000,
            "humanApprovalTimeout": 3600000
          },
          "delivery": {
            "default": {
              "mode": "smart",
              "broadcastKeywords": ["decision", "decisión", "escalation", "escalación", "blocker", "review", "revisión", "approval", "aprobación", "deploy", "release", "rollback", "incident", "incidencia", "hotfix"],
              "broadcastPriorities": ["urgent"]
            },
            "agents": {
              "pm":        { "mode": "broadcast" },
              "tech-lead": { "mode": "smart" },
              "po":        { "mode": "smart" },
              "back-1":    { "mode": "internal" },
              "front-1":   { "mode": "internal" },
              "qa":        { "mode": "smart" },
              "devops":    { "mode": "smart" },
              "designer":  { "mode": "internal" }
            },
            "agentAccounts": {
              "tech-lead": "tl",
              "designer":  "designer"
            }
          }
        }
      },
      "quality-gate": {
        "enabled": true,
        "config": {
          "coverageMinor": 70,
          "coverageMajor": 80,
          "maxAvgCyclomatic": 5.0
        }
      },
      "telegram-notifier": {
        "enabled": true,
        "config": {
          "groupId": "${TELEGRAM_GROUP_ID}",
          "rateLimit": {
            "maxPerMinute": 20
          }
        }
      },
      "stitch-bridge": {
        "enabled": true,
        "config": {
          "endpoint": "https://stitch.googleapis.com/mcp",
          "defaultProjectId": "16786124142182555397",
          "defaultModel": "GEMINI_3_PRO",
          "timeoutMs": 60000,
          "designDir": ".stitch-html"
        }
      },
      "model-router": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      }
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN_PM}",
      "dmPolicy": "open",
      "groupPolicy": "open",
      "allowFrom": ["*"],
      "streaming": "partial",
      "groups": {
        "-5177552677": {
          "enabled": true,
          "requireMention": true
        }
      },
      "accounts": {
        "pm": {
          "botToken": "${TELEGRAM_BOT_TOKEN_PM}"
        },
        "tl": {
          "botToken": "${TELEGRAM_BOT_TOKEN_TL}"
        },
        "designer": {
          "botToken": "${TELEGRAM_BOT_TOKEN_DESIGNER}"
        }
      }
    }
  },

  "skills": {
    "load": {
      "extraDirs": ["./skills"]
    }
  },

  "bindings": [
    { "agentId": "pm",        "match": { "channel": "telegram", "accountId": "pm" } },
    { "agentId": "tech-lead", "match": { "channel": "telegram", "accountId": "tl" } },
    { "agentId": "po",        "match": { "channel": "telegram", "accountId": "pm" } },
    { "agentId": "designer",  "match": { "channel": "telegram", "accountId": "designer" } },
    { "agentId": "back-1",    "match": { "channel": "telegram", "accountId": "pm" } },
    { "agentId": "front-1",   "match": { "channel": "telegram", "accountId": "pm" } },
    { "agentId": "qa",        "match": { "channel": "telegram", "accountId": "pm" } },
    { "agentId": "devops",    "match": { "channel": "telegram", "accountId": "pm" } }
  ],

  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": [
          "openai-codex/gpt-5.2",
          "github-copilot/gpt-4o"
        ]
      },
      "sandbox": {
        "mode": "off",
        "scope": "agent",
        "workspaceAccess": "rw"
      }
    },
    "list": [
      {
        "id": "pm",
        "name": "Product Manager",
        "default": true,
        "identity": { "name": "PM" },
        "model": { "primary": "openai-codex/gpt-5.2", "fallbacks": ["anthropic/claude-sonnet-4-6", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "agentDir": ".agent/agents/pm",
        "skills": ["requirements-grooming"],
        "subagents": {
          "allowAgents": ["tech-lead", "po", "designer", "back-1", "front-1", "qa", "devops"]
        },
        "tools": {
          "allow": [
            "task_create", "task_get", "task_search", "task_update",
            "task_transition", "workflow_events_query",
            "project_list", "project_switch",
            "team_assign", "team_status", "team_message", "team_inbox", "team_reply",
            "pipeline_start", "pipeline_status",
            "decision_evaluate", "decision_log",
            "sessions_spawn"
          ]
        }
      },
      {
        "id": "tech-lead",
        "name": "Tech Lead",
        "identity": { "name": "Tech Lead" },
        "model": { "primary": "anthropic/claude-opus-4-6", "fallbacks": ["openai-codex/gpt-5.2", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "agentDir": ".agent/agents/tech-lead",
        "skills": ["tech-lead", "architecture-design", "code-review", "adr"],
        "subagents": {
          "allowAgents": ["back-1", "front-1", "designer", "qa", "devops"]
        },
        "tools": {
          "allow": [
            "task_create", "task_get", "task_search", "task_update",
            "task_transition", "workflow_step_run", "workflow_state_get",
            "workflow_events_query", "quality_gate",
            "team_assign", "team_status", "team_message", "team_inbox", "team_reply",
            "project_list", "project_switch",
            "pipeline_status", "pipeline_retry", "pipeline_skip",
            "decision_evaluate", "decision_log",
            "sessions_spawn"
          ]
        }
      },
      {
        "id": "po",
        "name": "Product Owner",
        "identity": { "name": "PO" },
        "model": { "primary": "github-copilot/gpt-4.1", "fallbacks": ["anthropic/claude-sonnet-4-6", "openai-codex/gpt-5.2"] },
        "workspace": "/workspaces/active",
        "skills": ["product-owner", "requirements-grooming"],
        "tools": {
          "allow": [
            "task_create", "task_get", "task_search", "task_update",
            "task_transition", "workflow_step_run", "workflow_state_get",
            "team_message", "team_inbox", "team_reply", "team_status",
            "decision_evaluate", "decision_log"
          ]
        }
      },
      {
        "id": "designer",
        "name": "UI/UX Designer",
        "identity": { "name": "Designer" },
        "model": { "primary": "github-copilot/gpt-4o", "fallbacks": ["anthropic/claude-sonnet-4-6", "openai-codex/gpt-5.2"] },
        "workspace": "/workspaces/active",
        "skills": ["ui-designer"],
        "tools": {
          "allow": [
            "task_get", "task_update", "task_transition",
            "workflow_step_run", "workflow_state_get",
            "design_generate", "design_edit", "design_get", "design_list",
            "team_message", "team_inbox", "team_reply",
            "decision_evaluate"
          ]
        }
      },
      {
        "id": "back-1",
        "name": "Senior Backend Developer",
        "identity": { "name": "Back-1" },
        "model": { "primary": "anthropic/claude-sonnet-4-6", "fallbacks": ["openai-codex/gpt-5.2", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["backend-dev", "tdd-implementation", "patterns"],
        "tools": {
          "allow": [
            "task_get", "task_update", "task_transition",
            "workflow_step_run", "workflow_state_get",
            "quality_tests", "quality_coverage", "quality_lint",
            "quality_complexity", "quality_gate",
            "team_message", "team_inbox", "team_reply",
            "decision_evaluate"
          ]
        }
      },
      {
        "id": "front-1",
        "name": "Senior Frontend Developer",
        "identity": { "name": "Front-1" },
        "model": { "primary": "anthropic/claude-sonnet-4-6", "fallbacks": ["openai-codex/gpt-5.2", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["frontend-dev", "tdd-implementation"],
        "tools": {
          "allow": [
            "task_get", "task_update", "task_transition",
            "workflow_step_run", "workflow_state_get",
            "quality_tests", "quality_coverage", "quality_lint",
            "quality_complexity", "quality_gate",
            "design_get", "design_list",
            "team_message", "team_inbox", "team_reply",
            "decision_evaluate"
          ]
        }
      },
      {
        "id": "qa",
        "name": "QA Engineer",
        "identity": { "name": "QA" },
        "model": { "primary": "anthropic/claude-sonnet-4-6", "fallbacks": ["openai-codex/gpt-5.2", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["qa-testing"],
        "tools": {
          "allow": [
            "task_get", "task_update", "task_transition",
            "workflow_step_run", "workflow_state_get",
            "quality_tests", "quality_coverage", "quality_lint",
            "quality_complexity", "quality_gate",
            "workflow_events_query",
            "team_message", "team_inbox", "team_reply",
            "decision_evaluate"
          ]
        }
      },
      {
        "id": "devops",
        "name": "DevOps Engineer",
        "identity": { "name": "DevOps" },
        "model": { "primary": "anthropic/claude-sonnet-4-6", "fallbacks": ["openai-codex/gpt-5.2", "github-copilot/gpt-4o"] },
        "workspace": "/workspaces/active",
        "skills": ["devops", "github-automation"],
        "tools": {
          "allow": [
            "vcs_branch_create", "vcs_pr_create", "vcs_pr_update",
            "vcs_label_sync", "task_get", "task_search", "task_update",
            "task_transition", "workflow_state_get", "workflow_events_query",
            "project_list", "project_switch",
            "team_message", "team_inbox", "team_reply",
            "pipeline_status",
            "decision_evaluate"
          ]
        }
      }
    ]
  },

  "ui": {
    "seamColor": "#6366f1",
    "assistant": {
      "name": "Product Team",
      "avatar": "🏭"
    }
  }
}
